# Copy to .env and fill in. .env is gitignored — never commit real credentials.
# Email delivery uses a Gmail APP PASSWORD (not your login password, not an API key).
# Create one at: https://myaccount.google.com/apppasswords  (requires 2-Step Verification)

EMAIL_FROM=youraddress@gmail.com
EMAIL_APP_PASSWORD=abcd efgh ijkl mnop
EMAIL_TO=youraddress@gmail.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
